---
import BaseLayout from "../../layouts/BaseLayout.astro";
import site from "../../data/site.json";
---

<BaseLayout title={`Политика конфиденциальности — ${site.company.name}`} description="Политика обработки персональных данных (заготовка).">
  <section class="surface card">
    <div class="kicker">Документы</div>
    <h1 class="h1" style="margin-top: 8px">Политика конфиденциальности</h1>
    <p class="muted" style="margin-top: 10px">
      Заготовка. Сюда добавляется ваш юридически корректный текст (обработка персональных данных, формы на сайте и т.п.).
    </p>
  </section>
</BaseLayout>

