---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import site from "../../../data/site.json";
import allDocs from "../../../data/documents.json";
import DocumentsList from "../../../components/DocumentsList.astro";

const docs = allDocs.documents.filter((d) => d.category === "Сертификаты");
---

<BaseLayout title={`Сертификаты — ${site.company.name}`} description="Сертификаты и подтверждение соответствия для фасадных решений и материалов.">
  <div class="grid cols-2">
    <section class="surface card">
      <div class="kicker">Технический раздел</div>
      <h1 class="h1" style="margin-top: 8px">Сертификаты</h1>
      <p class="muted" style="margin-top: 10px">
        Публикуем актуальные сертификаты/протоколы. При необходимости подготовим комплект документов под
        конкретный проект и состав системы.
      </p>
      <div style="margin-top: 12px; display:flex; gap:10px; flex-wrap:wrap">
        <a class="btn ghost" href="/proektirovshchikam/">Запросить комплект документов</a>
        <a class="btn ghost" href="/tehnicheskij-razdel/">Все разделы</a>
      </div>
    </section>
    <DocumentsList title="Материалы (PDF)" docs={docs} />
  </div>
</BaseLayout>

