---
import BaseLayout from "../layouts/BaseLayout.astro";
import site from "../data/site.json";

type Slide = {
	title: string;
	subtitle: string;
	bullets: string[];
	image: string;
	href: string;
	cta: string;
};

const slides = (site.media.heroSlides as Slide[]) ?? [];
const home = site.home;
const productGroups = (site.menus?.productGroups as any[]) ?? [];

const web3Key = site.form?.web3formsAccessKey;
const useWeb3Forms = web3Key && String(web3Key).trim().length > 0;
const formEmail = site.form?.email || site.contacts.salesEmail;
const useFormSubmit = !useWeb3Forms && site.form?.useFormSubmit && formEmail;
const formAction = useWeb3Forms ? 'https://api.web3forms.com/submit' : (useFormSubmit && formEmail ? `https://formsubmit.co/${encodeURIComponent(formEmail)}` : "/api/lead");
const siteUrl = site.siteUrl || "https://steelfasad.example";
---

<BaseLayout title={site.seo.defaultTitle} description={site.seo.defaultDescription}>

	<!-- HERO SLIDER -->
	<section class="hp-slider-section fullbleed">
		<div class="hp-slider" id="hpSlider">
			<div class="hp-slides" id="hpSlides">
				{slides.map((s, idx) => (
					<div class="hp-slide" data-idx={idx}>
						<img src={s.image} alt={s.title} loading={idx === 0 ? "eager" : "lazy"} />
						<div class="hp-slide-overlay"></div>
						<div class="container"><div class="hp-slide-content">
							<span class="hp-slide-kicker">Производство и поставка по всей России</span>
							<h2 class="hp-slide-title">{s.title}</h2>
							<p class="hp-slide-subtitle">{s.subtitle}</p>
							<ul class="hp-slide-bullets">
								{s.bullets.map((b) => (
									<li>{b}</li>
								))}
							</ul>
						<div class="hp-slide-actions">
							<a class="hp-btn hp-btn-primary" href={s.href}>{s.cta}</a>
							<a class="hp-btn hp-btn-outline" href="/kontakty/">Консультация</a>
						</div>
					</div></div>
					</div>
				))}
			</div>
			<div class="hp-slider-nav">
				<button type="button" class="hp-arrow" id="hpPrev" aria-label="Назад">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
				</button>
				<div class="hp-dots" id="hpDots">
					{slides.map((_, idx) => (
						<button type="button" class={`hp-dot ${idx === 0 ? 'active' : ''}`} data-dot={idx} aria-label={`Слайд ${idx + 1}`}></button>
					))}
				</div>
				<button type="button" class="hp-arrow" id="hpNext" aria-label="Вперёд">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
				</button>
			</div>
		</div>
	</section>

	<!-- ABOUT -->
	<section class="hp-section">
		<div class="hp-section-header">
			<h2>СтилФас — проектирование и производство фасадных решений</h2>
			<p class="hp-muted">Собственное производство рядом с Екатеринбургом. Работаем с застройщиками, подрядчиками и архитекторами.</p>
		</div>
		<div class="hp-about-grid">
			<div class="hp-about-text">
				<p>{site.company.about}</p>
				<p><strong>Миссия:</strong> {home.mission}</p>
				<div class="hp-about-actions">
					<a class="hp-btn hp-btn-primary" href="/kalkulyator/">Рассчитать стоимость</a>
					<a class="hp-btn hp-btn-ghost" href="/kompaniya/">О компании</a>
				</div>
			</div>
			<div class="hp-about-stats">
				<div class="hp-stat">
					<span class="hp-stat-num">50+</span>
					<span class="hp-stat-label">реализованных объектов</span>
				</div>
				<div class="hp-stat">
					<span class="hp-stat-num">25+</span>
					<span class="hp-stat-label">лет срок службы</span>
				</div>
				<div class="hp-stat">
					<span class="hp-stat-num">RAL</span>
					<span class="hp-stat-label">любой цвет</span>
				</div>
				<div class="hp-stat">
					<span class="hp-stat-num">РФ</span>
					<span class="hp-stat-label">доставка по России</span>
				</div>
			</div>
		</div>
	</section>

	<!-- PRODUCTS CATALOG -->
	<section class="hp-section hp-products-section fullbleed">
		<div class="container">
			<div class="hp-section-header">
				<h2>Продукция</h2>
				<p class="hp-muted">Полный спектр фасадных и металлических изделий</p>
			</div>
			<div class="hp-products-grid">
				{productGroups.map((group) => (
					<a href={group.href} class="hp-product-card">
						<div class="hp-product-icon">
							{group.title === 'Металлокассеты' && '◼'}
							{group.title === 'Фасонные изделия' && '◢'}
							{group.title === 'Решётки' && '▦'}
							{group.title === 'Поддоны для бетонных дорожек' && '▬'}
							{group.title === 'Короба для кондиционеров' && '▣'}
							{group.title === 'Кровельные элементы' && '△'}
							{group.title === 'Колпаки' && '▲'}
							{group.title === 'Экраны для радиаторов' && '▤'}
						</div>
						<h3 class="hp-product-title">{group.title}</h3>
						<span class="hp-product-count">{group.items?.length || group.specs?.reduce((a: number, s: any) => a + s.items.length, 0) || 0} позиций</span>
						<span class="hp-product-arrow">→</span>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- ADVANTAGES -->
	<section class="hp-section">
		<div class="hp-section-header">
			<h2>Почему выбирают нас</h2>
			<p class="hp-muted">Преимущества работы с СтилФас</p>
		</div>
		<div class="hp-adv-grid">
			{home.advantages.map((a, idx) => (
				<div class="hp-adv-card">
					<span class="hp-adv-num">{String(idx + 1).padStart(2, '0')}</span>
					<h3>{a.title}</h3>
					<p>{a.text}</p>
				</div>
			))}
		</div>
	</section>

	<!-- APPLICATION -->
	<section class="hp-section hp-app-section fullbleed">
		<div class="container">
			<div class="hp-section-header">
				<h2>Область применения</h2>
				<p class="hp-muted">Подходят для любых типов зданий и климатических условий</p>
			</div>
			<div class="hp-app-grid">
				{home.application.map((a) => (
					<a class="hp-app-card" href={a.href}>
						<h3>{a.title}</h3>
						<span class="hp-app-arrow">→</span>
					</a>
				))}
			</div>
			<div class="hp-app-link">
				<a class="hp-btn hp-btn-ghost" href="/obekty/">Перейти в галерею объектов</a>
			</div>
		</div>
	</section>

	<!-- GALLERY -->
	<section class="hp-section">
		<div class="hp-section-header">
			<h2>Реализованные объекты</h2>
			<p class="hp-muted">Наши фасадные решения на реальных зданиях</p>
		</div>
		<div class="hp-gallery-grid">
			<a href="/obekty/" class="hp-gallery-card hp-gallery-large">
				<div class="hp-gallery-img">
					<span>Фото объекта 1</span>
				</div>
				<div class="hp-gallery-info">
					<span class="hp-gallery-tag">Бизнес-центр</span>
					<h3>Бизнес-центр, Екатеринбург</h3>
					<p>Металлокассеты закрытого типа, PVDF</p>
				</div>
			</a>
			<a href="/obekty/" class="hp-gallery-card">
				<div class="hp-gallery-img">
					<span>Фото объекта 2</span>
				</div>
				<div class="hp-gallery-info">
					<span class="hp-gallery-tag">Жилой комплекс</span>
					<h3>ЖК, Свердловская обл.</h3>
				</div>
			</a>
			<a href="/obekty/" class="hp-gallery-card">
				<div class="hp-gallery-img">
					<span>Фото объекта 3</span>
				</div>
				<div class="hp-gallery-info">
					<span class="hp-gallery-tag">Промышленный</span>
					<h3>Производственное здание</h3>
				</div>
			</a>
			<a href="/obekty/" class="hp-gallery-card">
				<div class="hp-gallery-img">
					<span>Фото объекта 4</span>
				</div>
				<div class="hp-gallery-info">
					<span class="hp-gallery-tag">Торговый центр</span>
					<h3>ТРЦ, Тюмень</h3>
				</div>
			</a>
		</div>
		<div class="hp-gallery-link">
			<a class="hp-btn hp-btn-primary" href="/obekty/">Все объекты →</a>
		</div>
	</section>

	<!-- PARTNERS -->
	<section class="hp-section">
		<div class="hp-section-header">
			<h2>Наши партнёры</h2>
		</div>
		<div class="hp-partners-grid">
			{home.partners.map((p) => (
				<div class="hp-partner">{p.name}</div>
			))}
		</div>
	</section>

	<!-- CERTIFICATES -->
	<section class="hp-section hp-certs-section fullbleed">
		<div class="container">
			<div class="hp-section-header">
				<h2>Сертификаты и документация</h2>
				<p class="hp-muted">Полный пакет документов для согласования и прохождения экспертизы</p>
			</div>
			<div class="hp-certs-grid">
				<div class="hp-cert-card">
					<div class="hp-cert-img">
						<span>Сертификат<br/>соответствия</span>
					</div>
					<h3>Сертификат соответствия</h3>
					<p>Подтверждение соответствия продукции требованиям технических регламентов РФ</p>
				</div>
				<div class="hp-cert-card">
					<div class="hp-cert-img">
						<span>Пожарный<br/>сертификат</span>
					</div>
					<h3>Пожарный сертификат</h3>
					<p>Класс пожарной безопасности НГ — негорючий материал</p>
				</div>
				<div class="hp-cert-card">
					<div class="hp-cert-img">
						<span>Паспорт<br/>качества</span>
					</div>
					<h3>Паспорт качества</h3>
					<p>Протоколы испытаний и контроль качества каждой партии</p>
				</div>
			</div>
			<div class="hp-certs-link">
				<a class="hp-btn hp-btn-ghost" href="/tehnicheskij-razdel/sertifikaty/">Все сертификаты и документы</a>
			</div>
		</div>
	</section>

	<!-- CALCULATOR TEASER -->
	<section class="hp-calc-section fullbleed">
		<div class="container">
			<div class="hp-calc-block">
				<div class="hp-calc-icon">
					<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="10" y2="10"/><line x1="12" y1="10" x2="14" y2="10"/><line x1="16" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="10" y2="14"/><line x1="12" y1="14" x2="14" y2="14"/><line x1="16" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="10" y2="18"/><line x1="12" y1="18" x2="16" y2="18"/></svg>
				</div>
				<div class="hp-calc-text">
					<h2>Рассчитайте стоимость за 30 секунд</h2>
					<p>Укажите площадь фасада, тип кассет и покрытие — получите ориентировочную стоимость сразу. Детальный расчёт подготовим за 1–3 дня.</p>
				</div>
				<a class="hp-btn hp-btn-primary hp-calc-btn" href="/kalkulyator/">Открыть калькулятор</a>
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section class="hp-section">
		<div class="hp-section-header">
			<h2>Часто задаваемые вопросы</h2>
			<p class="hp-muted">Ответы на популярные вопросы о металлокассетах и работе с нами</p>
		</div>
		<div class="hp-faq-list">
			<details class="hp-faq-item">
				<summary>Какой минимальный объём заказа?</summary>
				<p>Минимального порога нет — работаем как с небольшими объектами (от 50 м²), так и с крупными проектами. Стоимость за м² зависит от объёма: чем больше партия, тем выгоднее цена.</p>
			</details>
			<details class="hp-faq-item">
				<summary>Какие сроки производства?</summary>
				<p>Стандартные кассеты — от 5 рабочих дней. Нестандартные форматы и сложные покрытия (PVDF, HDP) — от 10 рабочих дней. Точные сроки зависят от объёма и загрузки производства.</p>
			</details>
			<details class="hp-faq-item">
				<summary>Вы доставляете по всей России?</summary>
				<p>Да, доставляем по всей РФ. Базовый регион — Екатеринбург и УрФО (1–2 дня). Доставка в другие регионы — через транспортные компании, сроки от 3 до 10 дней в зависимости от удалённости.</p>
			</details>
			<details class="hp-faq-item">
				<summary>Какие документы предоставляете?</summary>
				<p>Полный пакет: сертификаты соответствия, пожарные сертификаты, паспорта качества, протоколы испытаний. По запросу — альбом технических решений и конструктивные схемы узлов для прохождения экспертизы.</p>
			</details>
			<details class="hp-faq-item">
				<summary>Чем отличается открытый тип от закрытого?</summary>
				<p>Открытый тип — видимое крепление на заклёпки, дешевле на 15–25%, подходит для большинства объектов. Закрытый тип — скрытый замковый крепёж, монолитная плоскость фасада, применяется на объектах с высокими эстетическими требованиями.</p>
			</details>
			<details class="hp-faq-item">
				<summary>Можно заказать кассеты нестандартного размера?</summary>
				<p>Да, изготавливаем кассеты любого формата — от 200×200 до 2000×600 мм. Размеры определяются проектом. Помогаем с раскладкой и подбором оптимального модуля.</p>
			</details>
			<details class="hp-faq-item">
				<summary>Как получить расчёт стоимости?</summary>
				<p>Отправьте заявку через форму на сайте, калькулятор или позвоните. Укажите площадь фасада, тип кассет и желаемое покрытие. Мы подготовим коммерческое предложение за 1–3 рабочих дня.</p>
			</details>
		</div>
	</section>

	<!-- CTA -->
	<section class="hp-cta-section fullbleed">
		<div class="container">
			<div class="hp-cta-block">
				<div class="hp-cta-text">
					<h2>Готовы обсудить ваш проект?</h2>
					<p>Оставьте заявку — мы подготовим расчёт стоимости, подберём оптимальную систему и предоставим техническую документацию.</p>
					<div class="hp-cta-features">
						<span>✓ Расчёт за 1–3 дня</span>
						<span>✓ Бесплатная консультация</span>
						<span>✓ Выезд на объект</span>
					</div>
				</div>
				<div class="hp-cta-form">
					<h3>Быстрая заявка</h3>
					<form action={formAction} method="post" enctype="multipart/form-data">
						{useWeb3Forms && (
							<>
								<input type="hidden" name="access_key" value={web3Key} />
								<input type="hidden" name="subject" value="[Расчёт] Steelfas — заявка с главной" />
								<input type="hidden" name="redirect" value="" />
							</>
						)}
						{useFormSubmit && (
							<>
								<input type="hidden" name="_next" value={`${siteUrl}/spasibo/?type=${encodeURIComponent("Расчёт")}`} />
								<input type="hidden" name="_subject" value="[Расчёт] Steelfas — заявка с главной" />
								<input type="hidden" name="_captcha" value="false" />
							</>
						)}
						<input type="hidden" name="type" value="Расчёт" />
						<input type="hidden" name="context" value="Главная" />
						<input type="hidden" name="page" value="/" />
						<input type="text" name="name" placeholder="Ваше имя" class="hp-input" autocomplete="name" />
						<input type="tel" name="phone" placeholder="Телефон" class="hp-input" required autocomplete="tel" />
						<input type="text" name="city" placeholder="Город / Объект" class="hp-input" />
						<p class="form-pdp-consent">Нажимая кнопку «Отправить», вы даёте своё согласие на обработку персональных данных в соответствии с Федеральным законом от 27.07.2006 года №152-ФЗ «О персональных данных» на условиях и для целей, определённых в Согласии на обработку персональных данных.</p>
						<button type="submit" class="hp-btn hp-btn-primary hp-btn-full">Отправить заявку</button>
					</form>
					<p class="hp-form-hint">Или позвоните: <a href={`tel:${site.contacts.phone.replace(/[\s()-]/g, '')}`}>{site.contacts.phone}</a></p>
				</div>
			</div>
		</div>
	</section>

	<script>
		(() => {
			const slider = document.getElementById('hpSlider');
			const slides = document.getElementById('hpSlides');
			const prev = document.getElementById('hpPrev');
			const next = document.getElementById('hpNext');
			const dotsContainer = document.getElementById('hpDots');
			if (!slider || !slides || !prev || !next || !dotsContainer) return;

			const allSlides = slides.children;
			const total = allSlides.length;
			const dots = dotsContainer.querySelectorAll('.hp-dot');
			let current = 0;
			let timer: ReturnType<typeof setInterval> | null = null;
			let paused = false;

			function goTo(idx: number) {
				current = ((idx % total) + total) % total;
				slides!.style.transform = `translate3d(${-current * 100}%, 0, 0)`;
				dots.forEach((d, i) => d.classList.toggle('active', i === current));
			}

			function start() {
				if (timer || total <= 1) return;
				timer = setInterval(() => {
					if (!paused) goTo(current + 1);
				}, 5000);
			}

			function stop() {
				if (timer) { clearInterval(timer); timer = null; }
			}

			prev.addEventListener('click', () => { goTo(current - 1); stop(); start(); });
			next.addEventListener('click', () => { goTo(current + 1); stop(); start(); });

			dots.forEach(dot => {
				dot.addEventListener('click', () => {
					const idx = Number((dot as HTMLElement).dataset.dot);
					goTo(idx);
					stop();
					start();
				});
			});

			slider.addEventListener('mouseenter', () => { paused = true; });
			slider.addEventListener('mouseleave', () => { paused = false; });

			goTo(0);
			start();
		})();
	</script>
</BaseLayout>

<style>
	/* SLIDER */
	.hp-slider-section {
		padding: 0;
	}
	.hp-slider {
		position: relative;
		overflow: hidden;
		border-radius: 0 0 24px 24px;
	}
	.hp-slides {
		display: flex;
		transition: transform 500ms ease;
	}
	.hp-slide {
		position: relative;
		min-height: 520px;
		flex: 0 0 100%;
	}
	.hp-slide img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.hp-slide-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, rgba(10,5,5,0.92) 0%, rgba(10,5,5,0.7) 50%, rgba(10,5,5,0.3) 100%);
		z-index: 1;
	}
	.hp-slide > .container {
		position: relative;
		z-index: 2;
		height: 100%;
	}
	.hp-slide-content {
		color: #fff;
		padding-top: 60px;
		padding-bottom: 80px;
		max-width: 620px;
	}
	.hp-slide-kicker {
		display: inline-block;
		padding: 6px 16px;
		border-radius: 999px;
		background: rgba(255,255,255,0.1);
		border: 1px solid rgba(255,255,255,0.15);
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		margin-bottom: 22px;
	}
	.hp-slide-title {
		font-size: 48px;
		font-weight: 800;
		line-height: 1.08;
		margin: 0 0 16px;
		letter-spacing: -0.02em;
	}
	.hp-slide-subtitle {
