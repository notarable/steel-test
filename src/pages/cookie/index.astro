---
import BaseLayout from "../../layouts/BaseLayout.astro";
import site from "../../data/site.json";
---

<BaseLayout title={`Политика cookie — ${site.company.name}`} description="Политика использования cookie (заготовка).">
  <section class="surface card">
    <div class="kicker">Документы</div>
    <h1 class="h1" style="margin-top: 8px">Политика cookie</h1>
    <p class="muted" style="margin-top: 10px">
      Заготовка. Сюда добавляется описание используемых cookie и целей (аналитика, функциональные cookie и т.п.).
    </p>
  </section>
</BaseLayout>

