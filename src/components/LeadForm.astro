---
import site from '../data/site.json';

type Props = {
  type: "Расчёт" | "Консультация" | "Обратная связь" | "Запрос документации";
  context?: string;
  variant?: "full" | "phoneOnly";
};

const { type, context, variant = "full" } = Astro.props;
const isDemo = import.meta.env.PUBLIC_DEMO === 'true';
const contactMsg = `Демо-версия: заявка не отправляется. Для связи: ${site.contacts.phone} или ${site.contacts.email}`;
const action = isDemo ? '#' : '/api/lead';
---

<form class="form" action={action} method="post" enctype="multipart/form-data" data-demo={isDemo || undefined} data-demo-msg={isDemo ? contactMsg : undefined}>
  <input type="hidden" name="type" value={type} />
  <input type="hidden" name="context" value={context ?? ""} />
  <input type="hidden" name="page" value={Astro.url.pathname} />
  <input type="hidden" name="variant" value={variant} />

  {variant === "phoneOnly" ? (
    <>
      <div class="field">
        <label for="phone">Телефон</label>
        <input id="phone" name="phone" autocomplete="tel" required placeholder="+7 ..." />
        <div class="hint">Оставьте номер — перезвоним и уточним параметры.</div>
      </div>
      <div class="field">
        <label for="name">Имя (опционально)</label>
        <input id="name" name="name" autocomplete="name" />
      </div>
      <input type="hidden" name="message" value="Просьба связаться/перезвонить. Параметры уточнить по телефону." />
      <button class="btn primary" type="submit">Оставить номер</button>
    </>
  ) : (
    <>
      <div class="grid cols-2">
        <div class="field">
          <label for="name">Контактное лицо</label>
          <input id="name" name="name" autocomplete="name" />
        </div>
        <div class="field">
          <label for="company">Компания</label>
          <input id="company" name="company" autocomplete="organization" />
        </div>
      </div>

      <div class="grid cols-2">
        <div class="field">
          <label for="phone">Телефон</label>
          <input id="phone" name="phone" autocomplete="tel" />
          <div class="hint">Достаточно телефона или email.</div>
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" />
        </div>
      </div>

      <div class="grid cols-2">
        <div class="field">
          <label for="role">Роль (опционально)</label>
          <input id="role" name="role" placeholder="Проектировщик / Подрядчик / Застройщик..." />
        </div>
        <div class="field">
          <label for="city">Город/регион (опционально)</label>
          <input id="city" name="city" placeholder="Екатеринбург / РФ" />
        </div>
      </div>

      <div class="field">
        <label for="message">Комментарий (опционально)</label>
        <textarea
          id="message"
          name="message"
          placeholder="Если есть: тип объекта, раскладка/форматы, материал/покрытие, требования по ветру/пожару, сроки."
        />
      </div>

      <div class="field">
        <label for="file">Файл (опционально)</label>
        <input id="file" name="file" type="file" />
        <div class="hint">PDF/DWG/DXF/изображения. Ограничение обычно задаётся на сервере.</div>
      </div>

      <button class="btn primary" type="submit">Отправить</button>
    </>
  )}
</form>

{isDemo && (
  <script>
    document.querySelectorAll('form[data-demo]').forEach(form => {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        alert(form.dataset.demoMsg ?? 'Демо: заявка не отправляется');
      });
    });
  </script>
)}

