<!-- Floating AI Chat Widget -->
<div class="ai-widget-btn" id="aiWidgetBtn" aria-label="Открыть ИИ-консультант">
  <svg class="ai-widget-icon-chat" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
  <svg class="ai-widget-icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
</div>

<div class="ai-widget-popup" id="aiWidgetPopup">
  <div class="ai-widget-header">
    <div class="ai-widget-header-left">
      <div class="ai-widget-avatar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a4 4 0 0 1 4 4v1a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/><path d="M18 14a6 6 0 0 0-12 0v4a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-4z"/></svg>
      </div>
      <div>
        <strong>Steelfas AI</strong>
        <span class="ai-widget-status">Онлайн</span>
      </div>
    </div>
    <a href="/ai-konsultaciya/" class="ai-widget-expand" title="Открыть на полную страницу">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>
    </a>
  </div>

  <div class="ai-widget-messages" id="aiWidgetMessages">
    <div class="ai-msg ai-msg-bot">
      <div class="ai-msg-avatar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a4 4 0 0 1 4 4v1a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/><path d="M18 14a6 6 0 0 0-12 0v4a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-4z"/></svg>
      </div>
      <div class="ai-msg-bubble">
        <p>Здравствуйте! Чем могу помочь?</p>
      </div>
    </div>
  </div>

  <div class="ai-widget-suggestions" id="aiWidgetSuggestions">
    <button type="button" class="ai-suggestion" data-q="Какие цены на металлокассеты?">💰 Цены</button>
    <button type="button" class="ai-suggestion" data-q="Какие сроки производства?">⏱ Сроки</button>
    <button type="button" class="ai-suggestion" data-q="Чем отличается открытый тип от закрытого?">🔧 Типы</button>
    <button type="button" class="ai-suggestion" data-q="Какие покрытия доступны?">🎨 Покрытия</button>
  </div>

  <form class="ai-widget-input" id="aiWidgetForm">
    <input type="text" id="aiWidgetInput" placeholder="Ваш вопрос..." autocomplete="off" />
    <button type="submit" class="ai-send-btn" aria-label="Отправить">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2L15 22L11 13L2 9L22 2Z"/></svg>
    </button>
  </form>
</div>

<script>
  // ===== CHAT ENGINE (shared between page and widget) =====
  const AI_ENDPOINT = '/api/ai-chat';

  interface ChatInstance {
    messagesEl: HTMLElement;
    formEl: HTMLFormElement;
    inputEl: HTMLInputElement;
    suggestionsEl: HTMLElement | null;
    history: Array<{ role: string; content: string }>;
  }

  async function sendMessage(instance: ChatInstance, text: string) {
    if (!text.trim()) return;

    if (instance.suggestionsEl) instance.suggestionsEl.style.display = 'none';

    appendMessage(instance.messagesEl, text, 'user');
    instance.history.push({ role: 'user', content: text });
    instance.inputEl.value = '';

    const typingEl = appendTyping(instance.messagesEl);

    try {
      const response = await fetch(AI_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, history: instance.history.slice(-10) })
      });

      if (!response.ok) throw new Error('API error');
      const data = await response.json();
      typingEl.remove();
      appendMessage(instance.messagesEl, data.reply, 'bot');
      instance.history.push({ role: 'assistant', content: data.reply });
    } catch {
      typingEl.remove();
      const reply = getLocalReply(text);
      appendMessage(instance.messagesEl, reply, 'bot');
      instance.history.push({ role: 'assistant', content: reply });
    }
  }

  const BOT_AVATAR = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a4 4 0 0 1 4 4v1a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/><path d="M18 14a6 6 0 0 0-12 0v4a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-4z"/></svg>`;
  const USER_AVATAR = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`;

  function appendMessage(container: HTMLElement, text: string, role: 'user' | 'bot') {
    const msg = document.createElement('div');
    msg.className = `ai-msg ai-msg-${role}`;
    msg.innerHTML = `
      <div class="ai-msg-avatar">${role === 'bot' ? BOT_AVATAR : USER_AVATAR}</div>
      <div class="ai-msg-bubble"><p>${escapeHtml(text)}</p></div>
    `;
    container.appendChild(msg);
    container.scrollTop = container.scrollHeight;
  }

  function appendTyping(container: HTMLElement): HTMLElement {
    const el = document.createElement('div');
    el.className = 'ai-msg ai-msg-bot';
    el.innerHTML = `
      <div class="ai-msg-avatar">${BOT_AVATAR}</div>
      <div class="ai-msg-bubble"><div class="ai-typing"><span></span><span></span><span></span></div></div>
    `;
    container.appendChild(el);
    container.scrollTop = container.scrollHeight;
    return el;
  }

  function escapeHtml(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // Local fallback knowledge base
  function getLocalReply(q: string): string {
    const ql = q.toLowerCase();
    if (ql.includes('цен') || ql.includes('стоим') || ql.includes('сколько'))
      return 'Ориентировочные цены: от 790 ₽/м² (0.45 мм, полиэстер) до 2 490 ₽/м² (алюминий). Точная стоимость зависит от объёма, толщины и покрытия. Оставьте заявку — подготовим расчёт за 1–3 дня.';
    if (ql.includes('толщин') || ql.includes('0.45') || ql.includes('0.7') || ql.includes('1.0') || ql.includes('1.2'))
      return 'Доступные толщины: 0.45, 0.5, 0.7, 1.0, 1.2 и 1.5 мм. Самая популярная — 0.7 мм (оптимальный баланс цены и прочности). Для высотных зданий рекомендуем 1.0–1.5 мм.';
    if (ql.includes('открыт') || ql.includes('закрыт') || ql.includes('тип'))
      return 'Открытый тип — видимое крепление на заклёпки, дешевле на 15–25%. Закрытый тип — скрытый замковый крепёж, монолитная поверхность. Выбор зависит от эстетических требований и бюджета.';
    if (ql.includes('срок') || ql.includes('быстр') || ql.includes('когда') || ql.includes('долго'))
      return 'Стандартные кассеты — от 5 рабочих дней. Нестандартные форматы и PVDF/HDP — от 10 рабочих дней. Расчёт подготовим за 1–3 дня.';
    if (ql.includes('достав') || ql.includes('регион') || ql.includes('росси'))
      return 'Доставляем по всей РФ. Екатеринбург и УрФО — 1–2 дня. Другие регионы — 3–10 дней через транспортные компании. Упаковка на паллетах.';
    if (ql.includes('покрыт') || ql.includes('pvdf') || ql.includes('полиэстер') || ql.includes('порошк'))
      return 'Покрытия: Полиэстер (стандарт, 25 мкм), Порошковая окраска, PVDF (премиум, 35 мкм, стойкость 20+ лет), HDP (55 мкм, максимальная стойкость). Любой цвет RAL.';
    if (ql.includes('серти') || ql.includes('документ') || ql.includes('пожар'))
      return 'Предоставляем: сертификат соответствия, пожарный сертификат (класс НГ — негорючий), паспорт качества, протоколы испытаний. По запросу — альбом технических решений.';
    if (ql.includes('размер') || ql.includes('нестандарт') || ql.includes('формат'))
      return 'Стандартные размеры: от 400×400 до 2000×600 мм. Нестандартные — по чертежам заказчика, любой формат. Помогаем с раскладкой.';
    if (ql.includes('подсистем') || ql.includes('кронштейн') || ql.includes('направляющ'))
      return 'Поставляем подсистему: кронштейны, направляющие профили, крепёж. Комплексная поставка от одного производителя — гарантия совместимости. Расчёт под проект.';
    if (ql.includes('привет') || ql.includes('здравс') || ql.includes('добрый'))
      return 'Здравствуйте! Рад помочь. Спрашивайте о металлокассетах, ценах, сроках, покрытиях — отвечу на любой вопрос.';
    return 'Спасибо за вопрос! Для точного ответа рекомендую связаться с нашими специалистами по телефону или оставить заявку на сайте — подготовим ответ и расчёт за 1–3 дня.';
  }

  // ===== INIT FULL PAGE CHAT =====
  const fullMessages = document.getElementById('aiMessagesFull');
  const fullForm = document.getElementById('aiFormFull') as HTMLFormElement | null;
  const fullInput = document.getElementById('aiInputFull') as HTMLInputElement | null;
  const fullSuggestions = document.getElementById('aiSuggestionsFull');

  if (fullMessages && fullForm && fullInput) {
    const fullChat: ChatInstance = {
      messagesEl: fullMessages,
      formEl: fullForm,
      inputEl: fullInput,
      suggestionsEl: fullSuggestions,
      history: [],
    };

    fullForm.addEventListener('submit', (e) => {
      e.preventDefault();
      sendMessage(fullChat, fullInput.value);
    });

    fullSuggestions?.querySelectorAll('.ai-suggestion').forEach(btn => {
      btn.addEventListener('click', () => {
        sendMessage(fullChat, (btn as HTMLElement).dataset.q || '');
      });
    });
  }

  // ===== INIT WIDGET =====
  const widgetBtn = document.getElementById('aiWidgetBtn');
  const widgetPopup = document.getElementById('aiWidgetPopup');
  const widgetMessages = document.getElementById('aiWidgetMessages');
  const widgetForm = document.getElementById('aiWidgetForm') as HTMLFormElement | null;
  const widgetInput = document.getElementById('aiWidgetInput') as HTMLInputElement | null;
  const widgetSuggestions = document.getElementById('aiWidgetSuggestions');
  const iconChat = widgetBtn?.querySelector('.ai-widget-icon-chat') as HTMLElement;
  const iconClose = widgetBtn?.querySelector('.ai-widget-icon-close') as HTMLElement;

  if (widgetBtn && widgetPopup && widgetMessages && widgetForm && widgetInput) {
    const widgetChat: ChatInstance = {
      messagesEl: widgetMessages,
      formEl: widgetForm,
      inputEl: widgetInput,
      suggestionsEl: widgetSuggestions,
      history: [],
    };

    widgetBtn.addEventListener('click', () => {
      const isOpen = widgetPopup.classList.toggle('open');
      if (iconChat) iconChat.style.display = isOpen ? 'none' : '';
      if (iconClose) iconClose.style.display = isOpen ? '' : 'none';
    });

    widgetForm.addEventListener('submit', (e) => {
      e.preventDefault();
      sendMessage(widgetChat, widgetInput.value);
    });

    widgetSuggestions?.querySelectorAll('.ai-suggestion').forEach(btn => {
      btn.addEventListener('click', () => {
        sendMessage(widgetChat, (btn as HTMLElement).dataset.q || '');
      });
    });
  }
</script>

